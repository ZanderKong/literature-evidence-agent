# Literature Evidence Agent — Environment Configuration

# Workspace path (default: ./workspace)
EVIDENCE_AGENT_WORKSPACE=workspace

# Database path (relative to workspace, default: external_evidence/evidence.sqlite)
EVIDENCE_AGENT_DB_PATH=external_evidence/evidence.sqlite

# LLM Provider settings
EVIDENCE_AGENT_LLM_PROVIDER=mock
EVIDENCE_AGENT_LLM_MODEL=
EVIDENCE_AGENT_LLM_API_KEY=
EVIDENCE_AGENT_LLM_API_BASE=

# Maximum file size for PDF import (bytes, default: 100MB)
EVIDENCE_AGENT_MAX_FILE_SIZE=104857600
